# Server
PORT=3001

# Database (可选 — 留空时启动跳过 DB 初始化，业务调用 DB 才报错)
# DATABASE_URL=postgresql://novel:novel@127.0.0.1:5432/ai_novel_first_step

# JWT (开发可选 — 不设会用一次性随机 secret；生产环境必须设置)
# JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=30d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 免费共享算力（可选）
# 用于前端“免费共享算力”入口。要求目标服务兼容 OpenAI Chat Completions。
# 共享线路可能排队、超时、质量波动或不适合敏感文本；生产环境建议加限流和审计。
# SHARED_GPU_BASE_URL=https://your-shared-gpu.example.com/v1
# SHARED_GPU_MODEL=your-model-id
# SHARED_GPU_API_KEY=optional-backend-only-key
# SHARED_GPU_JSON_MODE=false
